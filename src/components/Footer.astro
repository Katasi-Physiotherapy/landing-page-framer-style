<style>
  .footer {
    background: var(--color-blue);
    color: var(--color-white);
    padding: 60px 24px 40px;
  }

  .footer__inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    margin-bottom: 48px;
  }

  .footer__heading {
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 16px;
    opacity: 0.7;
  }

  .footer__links li {
    margin-bottom: 10px;
  }

  .footer__links a {
    color: var(--color-white);
    opacity: 0.85;
    font-size: 0.95rem;
    transition: opacity 0.2s;
  }

  .footer__links a:hover {
    opacity: 1;
  }

  .footer__hours {
    font-size: 0.85rem;
    opacity: 0.6;
    margin-top: 12px;
    line-height: 1.4;
  }

  .footer__text {
    font-size: 0.95rem;
    opacity: 0.8;
    margin-bottom: 16px;
    line-height: 1.5;
  }

  .footer__form {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 12px;
  }

  .footer__input {
    width: 100%;
    padding: 14px 16px;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: transparent;
    color: var(--color-white);
    font-size: 0.95rem;
  }

  .footer__input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }

  .footer__disclaimer {
    font-size: 0.8rem;
    opacity: 0.6;
    line-height: 1.5;
  }

  .footer__disclaimer a {
    color: var(--color-white);
    text-decoration: underline;
  }

  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    padding-top: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    font-size: 0.85rem;
    opacity: 0.7;
  }

  .footer__social {
    display: flex;
    gap: 16px;
  }

  .footer__social a {
    color: var(--color-white);
    opacity: 0.7;
    transition: opacity 0.2s;
  }

  .footer__social a:hover {
    opacity: 1;
  }

  @media (min-width: 810px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr 2fr;
    }

    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
</style>
