---
const outcomes = [
  'Reduced pain',
  'Improved mobility',
  'Faster recovery',
  'Better posture',
  'Return to work or sport',
];
---

<section class="outcomes">
  <div class="container">
    <h2 class="outcomes__title">What you can expect</h2>
    <div class="outcomes__list">
      {outcomes.map((outcome) => (
        <span class="outcomes__pill">{outcome}</span>
      ))}
    </div>
  </div>
</section>

<style>
  .outcomes {
    padding: 80px 0;
  }

  .outcomes__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    text-align: center;
    margin-bottom: 48px;
    color: var(--color-blue);
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 400;
  }

  .outcomes__list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
  }

  .outcomes__pill {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: var(--color-cream-dark);
    border-radius: var(--radius-xl);
    font-weight: 500;
    font-size: 1rem;
    color: var(--color-text);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .outcomes__pill::before {
    content: '\2713';
    color: var(--color-green-dark);
    font-weight: 700;
    font-size: 1.1rem;
  }

  .outcomes__pill:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-elevated);
  }
</style>
