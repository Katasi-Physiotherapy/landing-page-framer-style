<section class="final-cta">
  <div class="final-cta__inner">
    <div class="container">
      <h2 class="final-cta__title">Ready to live pain-free again?</h2>
      <div class="final-cta__buttons">
        <a href="tel:+254705717353" class="btn final-cta__btn-primary">Call now</a>
        <a href="https://wa.me/254705717353?text=Hi%2C%20I'd%20like%20to%20book%20an%20appointment%20at%20Katasi%20Physiotherapy." target="_blank" rel="noopener noreferrer" class="btn final-cta__btn-outline">WhatsApp now</a>
      </div>
    </div>
  </div>
</section>

<style>
  .final-cta {
    padding: 80px 24px;
  }

  .final-cta__inner {
    background: var(--color-blue);
    border-radius: 40px;
    padding: 60px 40px;
    color: var(--color-white);
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .final-cta__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: 32px;
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 400;
    color: var(--color-white);
  }

  .final-cta__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: center;
  }

  .final-cta__btn-primary {
    background: var(--color-white);
    color: var(--color-blue);
    font-weight: 600;
    padding: 16px 40px;
    border-radius: var(--radius-xl);
  }

  .final-cta__btn-primary:hover {
    background: var(--color-cream);
    color: var(--color-blue);
  }

  .final-cta__btn-outline {
    background: transparent;
    color: var(--color-white);
    border: 2px solid var(--color-white);
    padding: 16px 40px;
    border-radius: var(--radius-xl);
    font-weight: 600;
  }

  .final-cta__btn-outline:hover {
    background: var(--color-white);
    color: var(--color-blue);
  }

  @media (min-width: 810px) {
    .final-cta__inner {
      padding: 80px 80px;
    }
  }
</style>
