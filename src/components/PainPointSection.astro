---
const painPoints = [
  'Persistent back or neck pain',
  'Shoulder or knee injuries',
  'Sports injuries that won\'t heal',
  'Stiffness from long hours at a desk',
  'Pain that keeps coming back',
];
---

<section class="pain-points">
  <div class="container">
    <h2 class="pain-points__title">Are you dealing with any of these?</h2>
    <ul class="pain-points__list">
      {painPoints.map((point) => (
        <li class="pain-points__item">{point}</li>
      ))}
    </ul>
    <p class="pain-points__message">
      You don't have to live with pain. With the right treatment, your body can heal and become stronger than before.
    </p>
  </div>
</section>

<style>
  .pain-points {
    padding: 80px 0;
    background: var(--color-cream-dark);
  }

  .pain-points__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    text-align: center;
    margin-bottom: 48px;
    color: var(--color-blue);
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 400;
  }

  .pain-points__list {
    max-width: 600px;
    margin: 0 auto 40px;
  }

  .pain-points__item {
    padding: 18px 24px;
    margin-bottom: 12px;
    background: var(--color-cream);
    border-radius: var(--radius-md);
    border-left: 4px solid var(--color-blue);
    font-weight: 500;
    font-size: 1.05rem;
    color: var(--color-text);
    transition: transform 0.2s ease;
  }

  .pain-points__item:hover {
    transform: translateX(4px);
  }

  .pain-points__message {
    text-align: center;
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }
</style>
