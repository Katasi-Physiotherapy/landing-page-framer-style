---
const address = 'Mogotio Road off Muthithi Road, Westlands';
const phone = '0705 717 353';
const phoneRaw = '+254705717353';
const email = 'info@katasi.co.ke';
const openingHours = 'Mon\u2013Fri: 8am\u20136pm | Sat: By appointment';
---

<section class="location">
  <div class="container">
    <h2 class="location__title">Find Us</h2>
    <div class="location__grid">
      <div class="location__info">
        <div class="location__item">
          <span class="location__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </span>
          <div>
            <strong>Address</strong>
            <p>{address}<br />Nairobi, Kenya</p>
          </div>
        </div>
        <div class="location__item">
          <span class="location__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </span>
          <div>
            <strong>Phone</strong>
            <p><a href={`tel:${phoneRaw}`}>{phone}</a></p>
          </div>
        </div>
        <div class="location__item">
          <span class="location__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          </span>
          <div>
            <strong>WhatsApp</strong>
            <p><a href={`https://wa.me/${phoneRaw.replace('+', '')}`} target="_blank" rel="noopener noreferrer">Message us</a></p>
          </div>
        </div>
        <div class="location__item">
          <span class="location__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </span>
          <div>
            <strong>Opening Hours</strong>
            <p>{openingHours}</p>
          </div>
        </div>
        <div class="location__item">
          <span class="location__icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
          <div>
            <strong>Email</strong>
            <p><a href={`mailto:${email}`}>{email}</a></p>
          </div>
        </div>
      </div>
      <div class="location__map">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3988.8148000000003!2d36.8069!3d-1.2654!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x182f1737d2e39f2d%3A0x7c5d2b2b2b2b2b2b!2sMogotio%20Rd%2C%20Nairobi!5e0!3m2!1sen!2ske!4v1707897600000!5m2!1sen!2ske"
          width="100%"
          height="350"
          style="border:0; border-radius: var(--radius-lg);"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Katasi Physiotherapy location"
        ></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  .location {
    padding: 80px 0;
  }

  .location__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    text-align: center;
    margin-bottom: 48px;
    color: var(--color-blue);
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 400;
  }

  .location__grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 40px;
    align-items: start;
  }

  .location__item {
    display: flex;
    gap: 16px;
    margin-bottom: 32px;
  }

  .location__icon {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    background: var(--color-cream-dark);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-blue);
  }

  .location__item strong {
    display: block;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 4px;
  }

  .location__item p {
    font-size: 1.1rem;
    color: var(--color-text);
    line-height: 1.5;
  }

  .location__item a {
    color: var(--color-blue);
    font-weight: 500;
  }

  .location__item a:hover {
    text-decoration: underline;
  }

  .location__map {
    min-height: 350px;
    overflow: hidden;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-elevated);
  }

  @media (max-width: 809px) {
    .location__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
