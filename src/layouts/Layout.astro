---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'Best Physiotherapy & Chiropractic in Westlands, Nairobi. Back pain, sports physio, dry needling & sciatica care on Mogotio Rd. Book today', image } = Astro.props;
const defaultOgImage = new URL('/hero-og.jpg', Astro.site || 'https://katasi.co.ke').toString();
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://katasi.co.ke');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Katasi Physiotherapy</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={`${title} | Katasi Physiotherapy`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={image ? new URL(image, Astro.site || 'https://katasi.co.ke').toString() : defaultOgImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Katasi Physiotherapy`} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
  </body>
</html>
