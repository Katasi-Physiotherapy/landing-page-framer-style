---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'Best Physiotherapy & Chiropractic in Westlands, Nairobi. Back pain, sports physio, dry needling & sciatica care on Mogotio Rd. Book today', image } = Astro.props;
const siteUrl = Astro.site || 'https://katasiphysiotherapy.co.ke';
const defaultOgImage = new URL('/hero-og.jpg', siteUrl).toString();
const canonicalURL = new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = image ? new URL(image, siteUrl).toString() : defaultOgImage;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/logo_extracted_transparent.png" />
    <meta name="theme-color" content="#065598" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Katasi Physiotherapy</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:site_name" content="Katasi Physiotherapy" />
    <meta property="og:title" content={`${title} | Katasi Physiotherapy`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_KE" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${title} | Katasi Physiotherapy`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Physiotherapy",
      "name": "Katasi Physiotherapy",
      "description": "Expert physiotherapy and chiropractic care in Westlands, Nairobi. Specializing in back pain, sports injuries, dry needling, and sciatica treatment.",
      "url": siteUrl,
      "logo": new URL('/logo_extracted_transparent.png', siteUrl).toString(),
      "image": defaultOgImage,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Mogotio Rd",
        "addressLocality": "Westlands",
        "addressRegion": "Nairobi",
        "addressCountry": "KE"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": -1.2656,
        "longitude": 36.8065
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "info@katasi.co.ke",
        "contactType": "customer service",
        "areaServed": "KE"
      },
      "sameAs": [
        "https://www.instagram.com/physiotherapy.katasi_nairobi/",
        "https://www.tiktok.com/@katasiphysiotherapy",
        "https://ke.linkedin.com/in/moses-w-katasi-6b6605140"
      ]
    })} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
  </body>
</html>
