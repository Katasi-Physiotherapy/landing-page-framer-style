---
import Layout from '../../layouts/Layout.astro';

const specialties = [
  'Orthopedic Manual Therapy',
  'Professional Chiropractic Care',
  'Pelvic Floor Physiotherapy',
  'Functional and Performance Rehabilitation',
  'Dry Needling Therapy',
];

const whoWeServe = [
  { label: 'Acute Injuries', desc: 'Individuals recovering from acute injuries' },
  { label: 'Chronic Pain', desc: 'Clients managing chronic back, neck pain and other muscle and joint conditions' },
  { label: 'Post-Surgical Rehab', desc: 'Post-surgical rehabilitation patients' },
  { label: 'Pelvic Health', desc: 'Women requiring specialized pelvic health support' },
  { label: 'Athletes', desc: 'Athletes and active professionals seeking performance optimization' },
  { label: 'Corporate Wellness', desc: 'Corporate professionals experiencing persistent work-related pain' },
];

const values = [
  { title: 'Clinical Excellence', desc: 'We are committed to high standards of assessment, treatment, and continuous professional development to ensure safe and effective care.' },
  { title: 'Integrity & Ethics', desc: 'We practice transparently, responsibly, and within professional guidelines, prioritizing patient safety and trust at all times.' },
  { title: 'Patient-Centered Care', desc: 'Every treatment plan is tailored to the individual. We listen, educate, and involve our patients in their recovery journey.' },
  { title: 'Accountability', desc: 'We measure progress, track outcomes, and take responsibility for delivering meaningful results.' },
  { title: 'Innovation & Growth', desc: 'We embrace modern rehabilitation methods and continually refine our services to meet evolving healthcare needs.' },
  { title: 'Accessibility', desc: 'We believe quality physiotherapy and rehabilitation services should remain affordable and accessible within Kenya.' },
  { title: 'Collaboration', desc: 'We work closely with patients, corporates, insurers, and referring healthcare providers to ensure coordinated and comprehensive care.' },
];
---

<Layout
  title="About Katasi Physiotherapy"
  description="Katasi Physiotherapy Services offers orthopedic physiotherapy, chiropractic care, pelvic health and more in Nairobi. Precision in assessment, clarity in diagnosis, measurable results."
>
  <section class="hero">
    <div class="container hero__inner">
      <h1 class="hero__title">Precision in assessment. Clarity in diagnosis. Measurable results.</h1>
      <p class="hero__subtitle">
        Katasi Physiotherapy Services is based in Nairobi, offering orthopedic physiotherapy solutions and specialized services to individuals, professionals, corporates, and partner healthcare institutions across Kenya.
      </p>
      <a href="/services/" class="btn btn--green">View our services</a>
    </div>
  </section>

  <section class="gallery section">
    <div class="container">
      <div class="gallery__grid">
        <img src="/about-hero-1.png" alt="Katasi Physiotherapy" class="gallery__img" />
        <img src="/about-img.png" alt="Katasi Physiotherapy care" class="gallery__img" />
      </div>
    </div>
  </section>

  <section class="about-intro section">
    <div class="container">
      <div class="about-intro__content">
        <h2 class="section-heading section-heading--center">Our Approach</h2>
        <p class="about-intro__text">
          We believe recovery should be clear, structured, and results-focused. Our approach is simple: understand the real cause of your pain, create a personalized plan, treat appropriately and guide you step by step toward lasting improvement.
        </p>
      </div>
    </div>
  </section>

  <section class="who-we-are section">
    <div class="container">
      <h2 class="section-heading section-heading--center">Who We Are</h2>
      <p class="who-we-are__intro">
        Katasi Physiotherapy Services comprises a team of highly trained and experienced rehabilitation professionals committed to delivering comprehensive care that integrates advanced clinical reasoning with a holistic understanding of human movement.
      </p>
      <div class="specialties__grid">
        {specialties.map((s) => (
          <div class="specialty-pill">{s}</div>
        ))}
      </div>
    </div>
  </section>

  <section class="who-we-serve section">
    <div class="who-we-serve__inner">
      <div class="container">
        <h2 class="section-heading section-heading--center section-heading--light">Who We Serve</h2>
        <div class="serve__grid">
          {whoWeServe.map((item) => (
            <div class="serve-card">
              <h3 class="serve-card__title">{item.label}</h3>
              <p class="serve-card__desc">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="vision-mission section">
    <div class="container">
      <div class="vision-mission__grid">
        <div class="card">
          <h2 class="section-heading">Vision</h2>
          <p>To be a leading center of excellence in physiotherapy, chiropractic, and pelvic health rehabilitation in Kenya — recognized for clinical integrity, innovation, and measurable patient outcomes.</p>
        </div>
        <div class="card">
          <h2 class="section-heading">Mission</h2>
          <p>To deliver accessible, evidence-informed rehabilitation services that restore function, relieve pain, and empower individuals and organizations to achieve sustainable physical health through personalized, ethical, and results-driven care.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="core-values section">
    <div class="container">
      <h2 class="section-heading section-heading--center">Our Core Values</h2>
      <div class="core-values__grid">
        {values.map((v) => (
          <div class="card">
            <h3 class="card__title accent-italic">{v.title}</h3>
            <p>{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="contact-cta section">
    <div class="contact-cta__inner">
      <div class="container">
        <h2 class="section-heading section-heading--light section-heading--center">Get moving, get in touch!</h2>
        <div class="contact-cta__details">
          <div class="contact-cta__item">
            <strong>Address</strong>
            <p>Mogotio Road off Muthithi Road, Westlands, Nairobi</p>
          </div>
          <div class="contact-cta__item">
            <strong>Phone</strong>
            <p><a href="tel:+254705717353">0705 717 353</a></p>
          </div>
          <div class="contact-cta__item">
            <strong>Email</strong>
            <p><a href="mailto:info@katasi.co.ke">info@katasi.co.ke</a></p>
          </div>
        </div>
        <div class="contact-cta__buttons">
          <a href="tel:+254705717353" class="btn contact-cta__btn-primary">Call now</a>
          <a href="https://wa.me/254705717353?text=Hi%2C%20I'd%20like%20to%20book%20an%20appointment%20at%20Katasi%20Physiotherapy." target="_blank" rel="noopener noreferrer" class="btn btn--outline contact-cta__btn-outline">WhatsApp now</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: var(--color-blue);
    color: white;
    padding: 100px 0 80px;
  }

  .hero__inner {
    max-width: 800px;
  }

  .hero__title {
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.2;
    margin: 0 0 24px;
    color: white;
  }

  .hero__subtitle {
    font-size: 1.125rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.9);
    margin: 0 0 32px;
  }

  .section {
    padding: 80px 0;
  }

  .gallery {
    background: var(--color-cream);
  }

  .gallery__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .gallery__img {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: var(--radius-xl);
  }

  .about-intro {
    background: var(--color-cream);
  }

  .about-intro__content {
    max-width: 740px;
    margin: 0 auto;
    text-align: center;
  }

  .about-intro__text {
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--color-text-muted);
  }

  .who-we-are {
    background: var(--color-cream-dark);
  }

  .who-we-are__intro {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 40px;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .specialties__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }

  .specialty-pill {
    padding: 12px 24px;
    background: var(--color-cream);
    border-radius: var(--radius-xl);
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--color-blue);
    border: 1px solid rgba(6, 85, 152, 0.15);
  }

  .who-we-serve__inner {
    background: var(--color-blue);
    color: white;
  }

  .serve__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .serve-card {
    background: rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    padding: 28px 24px;
  }

  .serve-card__title {
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 400;
    font-size: 1.15rem;
    color: var(--color-green);
    margin-bottom: 10px;
  }

  .serve-card__desc {
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
  }

  .vision-mission {
    background: var(--color-cream-dark);
  }

  .vision-mission__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .card {
    background: var(--color-cream);
    border-radius: var(--radius-lg);
    padding: 40px 32px;
    box-shadow: var(--shadow-card);
  }

  .card__title {
    font-size: 1.25rem;
    margin: 0 0 16px;
  }

  .card p {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin: 0;
  }

  .section-heading {
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 400;
    font-size: 1.5rem;
    color: var(--color-blue);
    margin: 0 0 20px;
  }

  .section-heading--center {
    text-align: center;
    margin-bottom: 40px;
  }

  .section-heading--light {
    color: white;
  }

  .core-values {
    background: var(--color-cream);
  }

  .core-values__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .contact-cta {
    padding: 0;
  }

  .contact-cta__inner {
    background: var(--color-blue);
    color: white;
    padding: 80px 0;
    margin: 0 24px;
    border-radius: 40px;
    margin-bottom: 80px;
  }

  .contact-cta__details {
    display: flex;
    justify-content: center;
    gap: 48px;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .contact-cta__item {
    text-align: center;
  }

  .contact-cta__item strong {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.6;
    margin-bottom: 6px;
  }

  .contact-cta__item p {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.95);
    margin: 0;
  }

  .contact-cta__item a {
    color: var(--color-green);
  }

  .contact-cta__item a:hover {
    text-decoration: underline;
  }

  .contact-cta__buttons {
    display: flex;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .contact-cta__btn-primary {
    background: var(--color-white);
    color: var(--color-blue);
    font-weight: 600;
  }

  .contact-cta__btn-primary:hover {
    background: var(--color-cream);
  }

  .contact-cta__btn-outline {
    color: var(--color-white);
    border-color: var(--color-white);
  }

  .contact-cta__btn-outline:hover {
    background: var(--color-white);
    color: var(--color-blue);
  }

  @media (max-width: 809px) {
    .hero {
      padding: 60px 0;
    }

    .gallery__grid,
    .vision-mission__grid {
      grid-template-columns: 1fr;
    }

    .core-values__grid {
      grid-template-columns: 1fr;
    }

    .serve__grid {
      grid-template-columns: 1fr;
    }

    .section {
      padding: 60px 0;
    }

    .card {
      padding: 28px 24px;
    }

    .contact-cta__details {
      flex-direction: column;
      gap: 24px;
      align-items: center;
    }

    .contact-cta__inner {
      margin: 0 16px;
      margin-bottom: 60px;
      padding: 60px 0;
    }
  }

  @media (min-width: 810px) and (max-width: 1199px) {
    .serve__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
