---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Contact Us"
  description="Contact Katasi Physiotherapy in Westlands, Nairobi. From pain management to performance optimization, we're here to guide you toward a healthier, more active life."
>
  <section class="contact-hero">
    <div class="container">
      <h1 class="contact-hero__title">Let's talk</h1>
      <p class="contact-hero__subtitle">
        From pain management to performance optimization, we're here to understand your needs and guide you toward a healthier, more active life.
      </p>
    </div>
  </section>

  <section class="contact-content">
    <div class="container">
      <div class="contact-methods">
        <a href="mailto:info@katasi.co.ke" class="contact-method">
          <span class="contact-method__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </span>
          <span class="contact-method__label">Email</span>
          <span class="contact-method__value">info@katasi.co.ke</span>
        </a>
        <a href="tel:+254705717353" class="contact-method">
          <span class="contact-method__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
            </svg>
          </span>
          <span class="contact-method__label">Phone</span>
          <span class="contact-method__value">0705 717353</span>
        </a>
        <div class="contact-method contact-method--static">
          <span class="contact-method__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </span>
          <span class="contact-method__label">Location</span>
          <span class="contact-method__value">Mogotio Road off Muthithi Road, Westlands, Nairobi</span>
        </div>
        <div class="contact-method contact-method--static">
          <span class="contact-method__icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
            </svg>
          </span>
          <span class="contact-method__label">Opening Hours</span>
          <span class="contact-method__value">Mon–Fri: 8am–6pm | Sat: By appointment</span>
        </div>
      </div>

      <div class="contact-form-wrapper">
        <h2 class="contact-form__heading">Send us a message</h2>
        <form class="contact-form" action="#" method="POST">
          <div class="contact-form__row">
            <div class="contact-form__field">
              <label for="firstName">First Name <span class="required">*</span></label>
              <input type="text" id="firstName" name="firstName" required />
            </div>
            <div class="contact-form__field">
              <label for="lastName">Last Name <span class="required">*</span></label>
              <input type="text" id="lastName" name="lastName" required />
            </div>
          </div>
          <div class="contact-form__field">
            <label for="email">Email <span class="required">*</span></label>
            <input type="email" id="email" name="email" required />
          </div>
          <div class="contact-form__field">
            <label for="service">Service</label>
            <select id="service" name="service">
              <option value="">Select a service</option>
              <option value="physiotherapy">Physiotherapy</option>
              <option value="chiropractic">Chiropractic</option>
              <option value="sports-rehab">Sports Rehabilitation</option>
              <option value="dry-needling">Dry Needling</option>
              <option value="back-pain">Back Pain</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div class="contact-form__field">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5"></textarea>
          </div>
          <button type="submit" class="btn btn--green">Send Message</button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style>
  .contact-hero {
    padding: 80px 0 60px;
    background: var(--color-cream);
  }

  .contact-hero__title {
    font-family: var(--font-accent);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    color: var(--color-blue);
    margin: 0 0 20px;
  }

  .contact-hero__subtitle {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin: 0;
    max-width: 640px;
  }

  .contact-content {
    padding: 0 0 100px;
  }

  .contact-methods {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 24px;
    margin-bottom: 60px;
  }

  .contact-method {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 28px 24px;
    background: var(--color-cream-dark);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s ease;
  }

  .contact-method:hover {
    box-shadow: var(--shadow-elevated);
  }

  .contact-method--static {
    cursor: default;
  }

  .contact-method--static:hover {
    box-shadow: none;
  }

  .contact-method__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: var(--color-blue);
    color: var(--color-white);
    border-radius: var(--radius-sm);
  }

  .contact-method__icon svg {
    flex-shrink: 0;
  }

  .contact-method__label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-blue);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .contact-method__value {
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.5;
  }

  .contact-form-wrapper {
    max-width: 640px;
    background: var(--color-white);
    padding: 40px;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }

  .contact-form__heading {
    font-family: var(--font-accent);
    font-style: italic;
    font-size: 1.5rem;
    color: var(--color-blue);
    margin: 0 0 28px;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .contact-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .contact-form__field label {
    display: block;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: 8px;
  }

  .required {
    color: var(--color-blue);
  }

  .contact-form__field input,
  .contact-form__field select,
  .contact-form__field textarea {
    width: 100%;
    border: 1px solid var(--color-border);
    padding: 14px 16px;
    border-radius: var(--radius-sm);
    font-size: 1rem;
    font-family: var(--font-body);
    background: var(--color-white);
    color: var(--color-text);
  }

  .contact-form__field textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact-form__field input:focus,
  .contact-form__field select:focus,
  .contact-form__field textarea:focus {
    outline: none;
    border-color: var(--color-blue);
  }

  @media (max-width: 600px) {
    .contact-form__row {
      grid-template-columns: 1fr;
    }

    .contact-form-wrapper {
      padding: 24px;
    }
  }
</style>
