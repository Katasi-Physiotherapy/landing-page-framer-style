---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout
  title={post.data.title}
  description={post.data.description ?? post.data.title}
  image={post.data.coverImage}
>
  <article class="blog-post">
    <div class="container blog-post__container">
      <a href="/blog/" class="blog-post__back">← Back to blog</a>

      <header class="blog-post__header">
        {post.data.coverImage && (
          <div class="blog-post__cover">
            <img src={post.data.coverImage} alt="" />
          </div>
        )}
        <h1 class="blog-post__title">{post.data.title}</h1>
        <time class="blog-post__date" datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('en-GB', {
            day: 'numeric',
            month: 'long',
            year: 'numeric',
          })}
        </time>
      </header>

      <div class="blog-post__prose">
        <Content />
      </div>
    </div>
  </article>
</Layout>

<style>
  .blog-post {
    padding-bottom: 80px;
  }

  .blog-post__container {
    max-width: 720px;
  }

  .blog-post__back {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--color-blue);
    margin-bottom: 32px;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .blog-post__back:hover {
    opacity: 0.8;
  }

  .blog-post__cover {
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: 32px;
    background: var(--color-cream-dark);
  }

  .blog-post__cover img {
    width: 100%;
    height: auto;
    display: block;
  }

  .blog-post__title {
    font-family: var(--font-accent);
    font-style: italic;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 400;
    color: var(--color-blue);
    margin: 0 0 16px 0;
    line-height: 1.3;
  }

  .blog-post__date {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-bottom: 40px;
    display: block;
  }

  .blog-post__prose {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-text);
  }

  .blog-post__prose :global(h2) {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-blue);
    margin: 2.5em 0 0.75em 0;
  }

  .blog-post__prose :global(h3) {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 2em 0 0.5em 0;
  }

  .blog-post__prose :global(p) {
    margin: 0 0 1.25em 0;
  }

  .blog-post__prose :global(p:last-child) {
    margin-bottom: 0;
  }

  .blog-post__prose :global(ul),
  .blog-post__prose :global(ol) {
    margin: 0 0 1.25em 0;
    padding-left: 1.5em;
  }

  .blog-post__prose :global(ul) {
    list-style: disc;
  }

  .blog-post__prose :global(ol) {
    list-style: decimal;
  }

  .blog-post__prose :global(li) {
    margin-bottom: 0.5em;
  }

  .blog-post__prose :global(a) {
    color: var(--color-blue);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .blog-post__prose :global(a:hover) {
    opacity: 0.8;
  }

  .blog-post__prose :global(blockquote) {
    margin: 2em 0;
    padding-left: 1.5em;
    border-left: 4px solid var(--color-green);
    color: var(--color-text-muted);
    font-style: italic;
  }

  .blog-post__prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5em 0;
  }

  .blog-post__prose :global(img) {
    border-radius: var(--radius-md);
    margin: 1.5em 0;
  }

  .blog-post__prose :global(strong) {
    font-weight: 600;
  }

  .blog-post__prose :global(em) {
    font-style: italic;
  }
</style>
